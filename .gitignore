# Build output
build/
build-*/
out/
cmake-build-*/

# vcpkg (toolchain lives at $VCPKG_ROOT; per-project installs are generated)
vcpkg_installed/

# Local, machine-specific CMake presets
CMakeUserPresets.json

# Generated compilation database (tools read it from the build dir)
/compile_commands.json

# Python bytecode cache (the .claude/hooks/ scripts run under python3)
__pycache__/
*.pyc

# Caches and editor cruft
.cache/
.vs/
.vscode/
*.user
.DS_Store

# Object/artifact files
*.o
*.a
*.so
*.obj

# Local-only tooling/notes — intentionally never tracked. skills-lock.json is
# kept (the pinned-skills manifest); the installed skill files under .agents/ are
# not.
/docs/plans/
/.agents/
